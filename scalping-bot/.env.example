# Copy to .env and fill in. Real .env is gitignored.
# All vars are prefixed SCALPING_BOT_

# Environment: testnet (default) or mainnet.
# Do NOT set mainnet until Phase 6 paper trading + gating criteria met.
SCALPING_BOT_ENV=testnet

# Logging
SCALPING_BOT_LOG_LEVEL=INFO

# Bybit credentials (needed from Phase 1 onward, not Phase 0).
# Create on https://testnet.bybit.com/ -> API. Permissions: Read + Contract Trade.
# Do NOT grant Withdrawal or Transfer permissions.
SCALPING_BOT_BYBIT_API_KEY=
SCALPING_BOT_BYBIT_API_SECRET=

# Trading parameters
SCALPING_BOT_SYMBOL=BTCUSDT
SCALPING_BOT_STARTING_CAPITAL_USD=100.0

# Paths (relative to repo root)
SCALPING_BOT_DATA_DIR=./data
SCALPING_BOT_LOG_DIR=./logs
